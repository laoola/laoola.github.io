---
import { getCollection } from 'astro:content';
import Layout from '@/layouts/Layout.astro';

const blogPosts = await getCollection('blog', ({ data }) => !data.draft);
const sortedPosts = blogPosts.sort((a, b) =>
  new Date(b.data.date).getTime() - new Date(a.data.date).getTime()
);
---

<Layout title="思考" description="个人技术思考文章列表">
  <header class="mb-8">
    <h1 class="text-3xl md:text-4xl font-bold">思考</h1>
    <p class="text-muted-foreground">技术文章和思考记录</p>
  </header>

  <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
    {sortedPosts.map((post) => {
      const slug = post.id.replace(/\.(md|mdx)$/, '');
      return (
        <article class="p-6 border border-border rounded-lg hover:shadow-sm transition-shadow">
          <h2 class="text-xl font-semibold mb-2">
            <a href={`/blog/${slug}`} class="hover:text-primary transition-colors">
              {post.data.title}
            </a>
          </h2>
          <p class="text-muted-foreground text-sm mb-3">
            {new Date(post.data.date).toLocaleDateString('zh-CN', {
              year: 'numeric',
              month: 'long',
              day: 'numeric'
            })}
          </p>
          <p class="text-muted-foreground mb-4">{post.data.description}</p>
          {post.data.tags && (
            <div class="flex flex-wrap gap-2">
              {post.data.tags.map((tag) => (
                <span class="px-2 py-1 bg-muted rounded-full text-xs">
                  {tag}
                </span>
              ))}
            </div>
          )}
        </article>
      );
    })}
  </div>
</Layout>
