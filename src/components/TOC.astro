---
interface Props {
  headings: Array<{ level: number; title: string; id: string }>;
  isInline?: boolean;
}

const { headings, isInline = false } = Astro.props;
---

{isInline ? (
  <nav class="bg-muted rounded-lg p-3">
    <ul class="space-y-2">
      {headings.map((heading) => (
        <li class={`pl-${(heading.level - 1) * 3}`}>
          <a
            href={`#${heading.id}`}
            class="text-sm hover:text-primary transition-colors hover:underline"
          >
            {heading.title}
          </a>
        </li>
      ))}
    </ul>
  </nav>
) : (
  <div class="sticky top-8 p-4 rounded-lg bg-card border border-border">
    <h3 class="text-lg font-semibold mb-3">目录</h3>
    <nav>
      <ul class="space-y-1">
        {headings.map((heading) => (
          <li class={`pl-${(heading.level - 1) * 4}`}>
            <a
              href={`#${heading.id}`}
              class="text-sm hover:text-primary transition-colors"
            >
              {heading.title}
            </a>
          </li>
        ))}
      </ul>
    </nav>
  </div>
)}
