---
interface Props {
  headings: Array<{ level: number; title: string; id: string }>;
  isInline?: boolean;
}

const { headings, isInline = false } = Astro.props;
---

{isInline ? (
  <nav class="bg-muted rounded-lg p-3 max-h-[50vh] overflow-y-auto">
    <ul class="space-y-2">
      {headings.map((heading) => (
        <li class={`pl-${(heading.level - 1) * 2}`}>
          <a
            href={`#${heading.id}`}
            class="text-sm hover:text-primary transition-colors hover:underline"
          >
            {heading.title}
          </a>
        </li>
      ))}
    </ul>
  </nav>
) : (
  <div class="sticky top-8 p-4 rounded-lg bg-card border border-border">
    <h3 class="text-lg font-semibold mb-3">目录</h3>
    <nav class="max-h-[calc(100vh-8rem)] overflow-y-auto pr-1">
      <ul class="space-y-1">
        {headings.map((heading) => (
          <li class={`pl-${(heading.level - 1) * 2}`}>
            <a
              href={`#${heading.id}`}
              class={`text-sm hover:text-primary transition-colors block py-0.5 ${
                heading.level > 2 ? 'text-muted-foreground' : ''
              }`}
            >
              {heading.title}
            </a>
          </li>
        ))}
      </ul>
    </nav>
  </div>
)}
