---
interface Props {
  code: string;
  language: string;
  filename?: string;
}

const { code, language, filename } = Astro.props;
---

<div class="relative">
  {filename && (
    <div class="bg-muted text-muted-foreground text-sm px-4 py-2 rounded-t-lg border-b border-border">
      {filename}
    </div>
  )}
  <pre class="relative bg-muted rounded-lg p-4 overflow-x-auto">
    <code class={`language-${language}`}>{code}</code>
    <button
      class="absolute top-2 right-2 p-2 bg-background rounded-md hover:bg-accent transition-colors"
      onclick="navigator.clipboard.writeText(this.parentElement.querySelector('code').textContent)
        .then(() => {
          const originalText = this.innerHTML;
          this.innerHTML = '✓';
          setTimeout(() => {
            this.innerHTML = originalText;
          }, 2000);
        })
      "
    >
      📋
    </button>
  </pre>
</div>
